rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == 'admin';
    }

    match /apartments/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && request.auth.uid == userId;
      allow delete: if isAdmin() || (signedIn() && request.auth.uid == userId);
    }

    match /favorites/{docId} {
      allow read, write: if signedIn();
    }

    match /messages/{docId} {
      allow read, write: if signedIn();
    }

    match /bookings/{docId} {
      allow read, write: if signedIn();
    }
  }
}
