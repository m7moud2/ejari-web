rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Function to check if user is admin (requires custom claims or reading user doc)
    // Note: To save reads, basic rules often rely on auth token.
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }
    
    match /properties/{propertyId} {
      // Properties are public to read
      allow read: if true;
      // Only authenticated users can create/update their own properties
      // Actually, we'll allow any authenticated user for now, 
      // but ideally checking if request.resource.data.ownerId == request.auth.uid
      allow write: if isAuthenticated();
    }
    
    match /chats/{chatId} {
      allow read, write: if isAuthenticated();
    }
    
    match /messages/{messageId} {
      allow read, write: if isAuthenticated();
    }
    
    match /feedbacks/{feedbackId} {
      allow read, write: if isAuthenticated();
    }
    
    match /bookings/{bookingId} {
      allow read, write: if isAuthenticated();
    }

    match /viewings/{viewingId} {
      allow read, write: if isAuthenticated();
    }

    match /wallets/{walletId} {
      allow read, write: if isAuthenticated();
      match /transactions/{txId} {
        allow read, write: if isAuthenticated();
      }
    }
    
    // Fallback for any other collection (temporarily open for authenticated users)
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
