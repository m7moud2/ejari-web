rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasOnly(keys) {
      return request.resource.data.keys().hasOnly(keys);
    }

    function hasAll(keys) {
      return request.resource.data.keys().hasAll(keys);
    }

    function unchanged(field) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([field]);
    }

    function changedOnly(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
    }

    function validStatus(field, allowedStatuses) {
      return request.resource.data[field] in allowedStatuses;
    }

    function isServerTimestamp(field) {
      return request.resource.data[field] == request.time;
    }

    function validUserCreateKeys() {
      return hasOnly([
        'name',
        'email',
        'phone',
        'address',
        'role',
        'type',
        'requestedRole',
        'verificationStatus',
        'createdAt',
        'status'
      ]);
    }

    function validUserCreateRoleFields() {
      return (!('role' in request.resource.data) ||
              request.resource.data.role == 'tenant') &&
             (!('type' in request.resource.data) ||
              request.resource.data.type == 'tenant') &&
             (!('requestedRole' in request.resource.data) ||
              request.resource.data.requestedRole in [
                'tenant',
                'owner',
                'technician',
                'company'
              ]);
    }

    function requestedRoleNeedsApproval() {
      return request.resource.data.requestedRole in [
        'owner',
        'technician',
        'company'
      ];
    }

    function validUserCreateVerificationStatus() {
      return !('verificationStatus' in request.resource.data) ||
             (requestedRoleNeedsApproval() &&
              request.resource.data.verificationStatus == 'pending') ||
             (!requestedRoleNeedsApproval() &&
              request.resource.data.verificationStatus in ['verified', 'approved']);
    }

    function validUserCreateTimestamps() {
      return !('createdAt' in request.resource.data) ||
             isServerTimestamp('createdAt');
    }

    function validUserCreateStatus() {
      return !('status' in request.resource.data) ||
             request.resource.data.status == 'active';
    }

    function validUserCreate(userId) {
      return isSelf(userId) &&
             validUserCreateKeys() &&
             validUserCreateRoleFields() &&
             validUserCreateVerificationStatus() &&
             validUserCreateTimestamps() &&
             validUserCreateStatus();
    }

    function validUserUpdate(userId) {
      return isSelf(userId) &&
             changedOnly([
               'name',
               'phone',
               'address',
               'avatar',
               'photoUrl',
               'displayName',
               'language',
               'notificationPreferences',
               'updatedAt'
             ]) &&
             (unchanged('updatedAt') || isServerTimestamp('updatedAt'));
    }

    // Users can only access their own private profile in this phase.
    match /users/{userId} {
      allow read: if isSelf(userId);
      allow create: if validUserCreate(userId);
      allow update: if validUserUpdate(userId);
      allow delete: if false;
    }

    function isPropertyOwner() {
      return signedIn() && resource.data.ownerId == request.auth.uid;
    }

    function canReadProperty() {
      return resource.data.status == 'approved' ||
             (signedIn() && resource.data.ownerId == request.auth.uid);
    }

    function propertyCreateLockedFieldsAbsent() {
      return !('isApproved' in request.resource.data) &&
             !('isVerified' in request.resource.data) &&
             !('isFeatured' in request.resource.data) &&
             !('featuredUntil' in request.resource.data) &&
             !('rejectionReason' in request.resource.data) &&
             !('adminNotes' in request.resource.data);
    }

    function validPropertyCreate() {
      return signedIn() &&
             request.resource.data.ownerId == request.auth.uid &&
             request.resource.data.status == 'pending' &&
             propertyCreateLockedFieldsAbsent() &&
             (!('createdAt' in request.resource.data) ||
              isServerTimestamp('createdAt'));
    }

    function validPropertyOwnerUpdate() {
      return isPropertyOwner() &&
             unchanged('ownerId') &&
             unchanged('status') &&
             unchanged('isApproved') &&
             unchanged('isVerified') &&
             unchanged('isFeatured') &&
             unchanged('featuredUntil') &&
             unchanged('rejectionReason') &&
             unchanged('adminNotes') &&
             unchanged('createdAt') &&
             (unchanged('updatedAt') || isServerTimestamp('updatedAt'));
    }

    function isChatParticipant() {
      return signedIn() && request.auth.uid in resource.data.participants;
    }

    function isChatParticipantById(chatId) {
      return signedIn() &&
             request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function validOneToOneParticipants(participants) {
      return participants is list &&
             participants.size() == 2 &&
             participants[0] is string &&
             participants[1] is string &&
             participants[0].size() > 0 &&
             participants[1].size() > 0 &&
             participants[0] != participants[1];
    }

    function validChatCreateKeys() {
      return hasOnly([
        'participants',
        'otherUserName',
        'subtitle',
        'lastMessage',
        'lastMessageTime',
        'createdAt'
      ]);
    }

    function validChatCreate() {
      return signedIn() &&
             request.auth.uid in request.resource.data.participants &&
             validOneToOneParticipants(request.resource.data.participants) &&
             validChatCreateKeys() &&
             isServerTimestamp('createdAt') &&
             isServerTimestamp('lastMessageTime');
    }

    function validChatParticipantUpdate() {
      return isChatParticipant() &&
             changedOnly(['lastMessage', 'lastMessageTime', 'updatedAt']) &&
             unchanged('participants') &&
             unchanged('createdAt') &&
             unchanged('otherUserName') &&
             unchanged('subtitle') &&
             (unchanged('lastMessageTime') || isServerTimestamp('lastMessageTime')) &&
             (unchanged('updatedAt') || isServerTimestamp('updatedAt'));
    }

    function validMessageCreate() {
      return hasOnly(['senderId', 'text', 'timestamp']) &&
             request.resource.data.senderId == request.auth.uid &&
             request.resource.data.text is string &&
             request.resource.data.text.size() >= 1 &&
             request.resource.data.text.size() <= 2000 &&
             isServerTimestamp('timestamp');
    }

    function isPaymentParty() {
      return signedIn() &&
             (resource.data.userId == request.auth.uid ||
              resource.data.ownerId == request.auth.uid);
    }

    function isEscrowParty() {
      return signedIn() &&
             (resource.data.tenantId == request.auth.uid ||
              resource.data.ownerId == request.auth.uid);
    }

    function isBookingTenant() {
      return signedIn() && resource.data.tenantId == request.auth.uid;
    }

    function isBookingOwner() {
      return signedIn() && resource.data.ownerId == request.auth.uid;
    }

    function canReadBooking() {
      return isBookingTenant() || isBookingOwner();
    }

    function bookingPropertyOwnerMatches() {
      let property = get(/databases/$(database)/documents/properties/$(request.resource.data.propertyId));
      return property.data.ownerId == request.resource.data.ownerId &&
             property.data.status == 'approved';
    }

    function bookingCreateFinancialFieldsSafe() {
      return (!('paymentStatus' in request.resource.data) ||
              request.resource.data.paymentStatus == 'pending') &&
             (!('escrowStatus' in request.resource.data) ||
              request.resource.data.escrowStatus == 'none') &&
             (!('contractStatus' in request.resource.data) ||
              request.resource.data.contractStatus == 'none') &&
             (!('paidAmount' in request.resource.data) ||
              request.resource.data.paidAmount == 0) &&
             !('contractNumber' in request.resource.data) &&
             !('transactionId' in request.resource.data) &&
             !('paymentPhase' in request.resource.data);
    }

    function validBookingCreate() {
      return signedIn() &&
             request.resource.data.tenantId == request.auth.uid &&
             request.resource.data.propertyId is string &&
             request.resource.data.ownerId is string &&
             request.resource.data.status == 'pending' &&
             bookingPropertyOwnerMatches() &&
             bookingCreateFinancialFieldsSafe() &&
             (!('createdAt' in request.resource.data) ||
              isServerTimestamp('createdAt'));
    }

    function bookingFinancialFieldsUnchanged() {
      return unchanged('tenantId') &&
             unchanged('ownerId') &&
             unchanged('propertyId') &&
             unchanged('paymentStatus') &&
             unchanged('paidAmount') &&
             unchanged('escrowStatus') &&
             unchanged('contractStatus') &&
             unchanged('contractNumber') &&
             unchanged('transactionId') &&
             unchanged('paymentPhase') &&
             unchanged('createdAt');
    }

    function tenantCancelledBooking() {
      return resource.data.status == 'pending' &&
             request.resource.data.status == 'cancelled' &&
             changedOnly(['status', 'updatedAt']);
    }

    function tenantUpdatedBookingDetails() {
      return changedOnly(['specialRequests', 'verification', 'updatedAt']) &&
             unchanged('status');
    }

    function validTenantBookingUpdate() {
      return isBookingTenant() &&
             bookingFinancialFieldsUnchanged() &&
             (tenantCancelledBooking() || tenantUpdatedBookingDetails()) &&
             (unchanged('updatedAt') || isServerTimestamp('updatedAt'));
    }

    function validOwnerBookingStatusTransition() {
      let oldStatus = resource.data.status;
      let newStatus = request.resource.data.status;
      return (oldStatus == 'pending' || oldStatus == 'viewing_scheduled') &&
             (newStatus == 'approved' ||
              newStatus == 'accepted' ||
              newStatus == 'rejected');
    }

    function validOwnerBookingUpdate() {
      return isBookingOwner() &&
             changedOnly(['status', 'ownerNotes', 'updatedAt']) &&
             validOwnerBookingStatusTransition() &&
             bookingFinancialFieldsUnchanged() &&
             (unchanged('updatedAt') || isServerTimestamp('updatedAt'));
    }

    function isContractParty() {
      return signedIn() &&
             (resource.data.tenantId == request.auth.uid ||
              resource.data.ownerId == request.auth.uid);
    }

    // Public guests and tenants read approved listings only.
    // Owners can read their own listings regardless of review status.
    match /properties/{propertyId} {
      allow read: if canReadProperty();
      allow create: if validPropertyCreate();
      allow update: if validPropertyOwnerUpdate();
      allow delete: if isPropertyOwner();
    }

    // 1:1 chats only. Participants are immutable after creation.
    match /chats/{chatId} {
      allow read: if isChatParticipant();
      allow create: if validChatCreate();
      allow update: if validChatParticipantUpdate();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatParticipantById(chatId);
        allow create: if isChatParticipantById(chatId) && validMessageCreate();
        allow update: if false;
        allow delete: if false;
      }
    }

    // Financial collections are server-owned. Clients may read only their own records.
    // Wallet docs are summary views; walletTransactions are the ledger source of truth.
    match /wallets/{userId} {
      allow read: if isSelf(userId);
      allow create, update, delete: if false;
    }

    match /walletTransactions/{transactionId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if isPaymentParty();
      allow create, update, delete: if false;
    }

    match /escrow/{escrowId} {
      allow read: if isEscrowParty();
      allow create, update, delete: if false;
    }

    // Tenants create requests; owners approve/reject; financial state is server-owned.
    match /bookings/{bookingId} {
      allow read: if canReadBooking();
      allow create: if validBookingCreate();
      allow update: if validTenantBookingUpdate() || validOwnerBookingUpdate();
      allow delete: if false;
    }

    // Contracts are server-owned after approved/paid bookings. Parties may read only.
    match /contracts/{contractId} {
      allow read: if isContractParty();
      allow create, update, delete: if false;
    }

  }
}
