rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasOnly(keys) {
      return request.resource.data.keys().hasOnly(keys);
    }

    function hasAll(keys) {
      return request.resource.data.keys().hasAll(keys);
    }

    function unchanged(field) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([field]);
    }

    function changedOnly(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
    }

    function validStatus(field, allowedStatuses) {
      return request.resource.data[field] in allowedStatuses;
    }

    function isServerTimestamp(field) {
      return request.resource.data[field] == request.time;
    }

    // Allow users to read all users (for chat names) but only write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Properties
    // Anyone authenticated can read approved properties
    // Owners can create properties, and edit/delete their own
    match /properties/{propertyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // Chats
    // Users can only read or create chats if they are one of the participants
    match /chats/{chatId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null && request.auth.uid in resource.data.participants;
      
      // Messages inside a chat
      // Users can only read/write messages in chats they belong to
      match /messages/{messageId} {
        allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if request.auth != null 
                     && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
                     && request.resource.data.senderId == request.auth.uid;
      }
    }

  }
}
